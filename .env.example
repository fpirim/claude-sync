# Copy to .env and fill in. .env is gitignored.
#
# Remote host (for `make deploy` and `make setup`)
# DEPLOY_HOST=user@host         # or an SSH alias from ~/.ssh/config
# DEPLOY_KEY=~/path/to/key      # optional; omit if your agent or ~/.ssh/config handles it
# DEPLOY_ARCH=linux-arm64       # linux-arm64 | linux-amd64
#
# Syncthing auto-pairing (used by `make setup`)
# GUI_USER=admin                # username for Syncthing web UI on BOTH hosts
# GUI_PASSWORD=changeme         # password — set once, applied to local + remote
# FOLDER_ID=claude-home         # Syncthing folder identifier
# FOLDER_PATH=~/.claude         # folder path (same on every host)
